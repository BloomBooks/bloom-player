{
    "name": "bloom-player",
    "description": "A library for displaying Bloom books in iframes or WebViews",
    "author": "SIL Global",
    "license": "MIT",
    "version": "0.0.0",
    "packageManager": "pnpm@11.1.2",
    "private": false,
    "// sideeffects might need to be ['*.css'] to avoid 'shaking' our CSS, if we ever get tree shaking working": "",
    "sideEffects": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/BloomBooks/bloom-player.git"
    },
    "type": "module",
    "module": "lib/shared.es.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/shared.es.js",
            "default": "./lib/shared.es.js"
        }
    },
    "scripts": {
        "// COMMENTS: make the action a space rather than empty string so `pnpm run` can list the scripts": " ",
        "//": " ",
        "// 'pnpm dev' will build, watch, start a server, and open the player in a brower": " ",
        "// You can edit index-for-developing.html to point to different books": " ",
        "// Or just use 'pnpm storybook' and skip this dev approach entirely": " ",
        "dev": "vite",
        "build:standalone": "vite build",
        "build:sharedlib": "vite build --mode lib",
        "test": "vitest",
        "// blame.ignoreRevsFile - This allows blame to see through commits that are only there to format code.": " ",
        "prepare": "husky install && git config blame.ignoreRevsFile .git-blame-ignore-revs",
        "storybook": "storybook dev -p 6006",
        "// run this when working with stories that use an iframe and bloomplayer.htm instead of the raw react components": " ",
        "watchForStorybook": "pnpm vite build --watch --mode development",
        "strings:download": "crowdin download --config src/l10n/crowdin.yml  && pnpm strings:compile",
        "strings:upload": "crowdin upload  --config src/l10n/crowdin.yml",
        "strings:compile": "pnpm tsx ./src/l10n/compileL10Strings.ts",
        "strings:sync": "pnpm strings:upload && pnpm strings:download"
    },
    "dependencies": {
        "@material-ui/core": "4.12.4",
        "@material-ui/icons": "4.11.3",
        "@material-ui/styles": "4.11.5",
        "axios": "0.18.1",
        "compare-versions": "6.1.1",
        "dynamic-import-polyfill": "0.1.1",
        "jquery": "3.7.1",
        "jquery.nicescroll": "3.7.6",
        "react": "17.0.2",
        "react-dom": "17.0.2",
        "react-id-swiper": "2.3.2",
        "style-scoped": "0.2.2",
        "swiper": "4.5.1"
    },
    "devDependencies": {
        "@crowdin/cli": "4.14.2",
        "@storybook/addon-docs": "10.3.6",
        "@storybook/addon-links": "10.3.6",
        "@storybook/react-vite": "10.3.6",
        "@types/jquery": "3.5.34",
        "@types/jquery.nicescroll": "3.7.5",
        "@types/node": "22.19.18",
        "@types/react": "17.0.91",
        "@types/react-dom": "17.0.26",
        "editorconfig": "2.0.1",
        "eslint": "9.39.4",
        "eslint-plugin-storybook": "10.3.6",
        "glob": "10.5.0",
        "husky": "8.0.3",
        "jsdom": "25.0.1",
        "less": "4.6.4",
        "prettier": "3.8.3",
        "storybook": "10.3.6",
        "tsx": "4.21.0",
        "typescript": "6.0.3",
        "vite": "7.3.3",
        "vite-plugin-dts": "5.0.0",
        "vite-plugin-html": "3.2.2",
        "vite-plugin-static-copy": "3.4.0",
        "vitest": "4.1.6"
    },
    "// The four src/ files are directly exported so BloomDesktop can consume them as shared code.": "",
    "files": [
        "dist/*.js",
        "dist/bloomplayer.htm",
        "dist/*.mp3",
        "lib/*.js",
        "lib/*.d.ts",
        "lib/*.js.map",
        "src/shared/event.ts",
        "src/shared/narration.ts",
        "src/shared/dragActivityRuntime.ts",
        "src/shared/scrolling.ts",
        "src/shared/index.ts",
        "dist/*.css",
        "dist/*.tsv"
    ],
    "volta": {
        "node": "24.13.0",
        "pnpm": "11.1.2"
    }
}
